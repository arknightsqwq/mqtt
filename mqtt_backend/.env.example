# ═══════════════════════════════════════
# 环境配置模板 —— 复制为 .env 并修改
# ═══════════════════════════════════════

# ── 数据库 ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_db_password
DB_NAME=mqtt_device_db
DB_CHARSET=utf8mb4
# 连接池参数
DB_POOL_MIN=2
DB_POOL_MAX=5
DB_POOL_MAX_CONNS=10

# ── EMQX MQTT Broker ──
EMQX_HOST=192.168.5.4
EMQX_PORT=1883
EMQX_USER=BackEnd
EMQX_PASS=your_emqx_password
# ── MQTT 订阅主题（格式: topic:qos，逗号分隔）──
# telemetry=周期遥测(qos1) alert=告警(qos2) status=在线状态(qos1) data=兼容旧版(qos1)
SUBSCRIBE_TOPICS=device/+/telemetry:1,device/+/alert:2,device/+/status:1,device/+/data:1

# ── 服务 ──
API_HOST=0.0.0.0
API_PORT=8000
APP_TITLE=设备数据管理后端
CORS_ORIGINS=*
DEBUG=false

# ── JWT 认证 ──
JWT_SECRET=生成一个随机字符串替换这里
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── 管理员 ──
ADMIN_TOKEN=生成一个强密码替换这里

# ── 分页限制 ──
PAGE_SIZE_MAX=100
